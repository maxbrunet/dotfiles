{
  "mcpServers": {
    "gopls": {
      "type": "stdio",
      "command": "gopls",
      "args": ["mcp"]
    },
    "linear": {
      "url": "https://mcp.linear.app/mcp/"
    },
    "notion": {
      "url": "https://mcp.notion.com/mcp/"
    },
    "tavily": {
      "url": "https://mcp.tavily.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${env:TAVILY_API_KEY}"
      }
    }
  }
}
