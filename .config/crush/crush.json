{
  "$schema": "https://charm.land/crush.json",
  "lsp": {
    "bash": {
      "init_options": {
        "bashIde": {
          "shfmt": {
            "binaryNextLine": true,
            "caseIndent": true
          }
        }
      }
    }
  },
  "mcp": {
    "gopls": {
      "type": "stdio",
      "command": "gopls",
      "args": ["mcp"]
    },
    "tavily": {
      "type": "http",
      "url": "https://mcp.tavily.com/mcp/",
      "disable_standalone_sse": true,
      "headers": {
        "Authorization": "Bearer $TAVILY_API_KEY"
      }
    }
  },
  "models": {
    "large": {
      "model": "command-a-reasoning-08-2025",
      "provider": "cohere",
      "think": true
    },
    "small": {
      "model": "command-a-03-2025",
      "provider": "cohere"
    }
  },
  "options": {
    "attribution": { "generated_with": false },
    "disable_default_providers": true,
    "disable_metrics": true
  },
  "permissions": {
    "allowed_tools": [
      "git diff",
      "git log",
      "git show",
      "git status",
      "glob",
      "grep",
      "job_output",
      "list_mcp_resources",
      "ls",
      "lsp_diagnostics",
      "lsp_references",
      "mcp_gopls_go_diagnostics",
      "mcp_gopls_go_file_context",
      "mcp_gopls_go_package_api",
      "mcp_gopls_go_search",
      "mcp_gopls_go_symbol_references",
      "mcp_gopls_go_vulncheck",
      "mcp_gopls_go_workspace",
      "mcp_tavily_tavily_extract",
      "mcp_tavily_tavily_search",
      "read_mcp_resource",
      "todos",
      "view"
    ]
  },
  "providers": {
    "cohere": {
      "name": "Cohere",
      "type": "openai-compat",
      "base_url": "https://api.cohere.com/compatibility/v1",
      "api_key": "$CO_API_KEY",
      "models": [
        {
          "id": "command-a-03-2025",
          "name": "Command A 03-2025",
          "cost_per_1m_in": 2.5,
          "cost_per_1m_out": 10,
          "cost_per_1m_in_cached": 0,
          "cost_per_1m_out_cached": 0,
          "context_window": 256000,
          "default_max_tokens": 8000,
          "can_reason": true,
          "options": {},
          "supports_attachments": false
        },
        {
          "id": "command-a-reasoning-08-2025",
          "name": "Command A Reasoning 08-2025",
          "cost_per_1m_in": 0,
          "cost_per_1m_out": 0,
          "cost_per_1m_in_cached": 0,
          "cost_per_1m_out_cached": 0,
          "context_window": 256000,
          "default_max_tokens": 32000,
          "can_reason": true,
          "options": {},
          "supports_attachments": false
        },
        {
          "id": "command-r7b-12-2024",
          "name": "Command R7B 12-2024",
          "cost_per_1m_in": 0.0375,
          "cost_per_1m_out": 0.15,
          "cost_per_1m_in_cached": 0,
          "cost_per_1m_out_cached": 0,
          "context_window": 128000,
          "default_max_tokens": 4000,
          "can_reason": false,
          "options": {},
          "supports_attachments": false
        },
        {
          "id": "command-r-08-2024",
          "name": "Command R 08-2024",
          "cost_per_1m_in": 0.15,
          "cost_per_1m_out": 0.6,
          "cost_per_1m_in_cached": 0,
          "cost_per_1m_out_cached": 0,
          "context_window": 128000,
          "default_max_tokens": 4000,
          "can_reason": false,
          "options": {},
          "supports_attachments": false
        },
        {
          "id": "command-r-plus-08-2024",
          "name": "Command R+ 08-2024",
          "cost_per_1m_in": 2.5,
          "cost_per_1m_out": 10,
          "cost_per_1m_in_cached": 0,
          "cost_per_1m_out_cached": 0,
          "context_window": 128000,
          "default_max_tokens": 4000,
          "can_reason": false,
          "options": {},
          "supports_attachments": false
        }
      ]
    }
  },
  "tools": {
    "grep": {},
    "ls": {}
  }
}
